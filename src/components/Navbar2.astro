              href="#proyectos"
            >
              Proyectos
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-yellow-500 transition-all group-hover:w-full"></span>
            </a>
          </li>
          <li>
            <a 
              class="text-sm font-medium text-gray-700 hover:text-yellow-500 transition-colors relative group" 
              href="#arquetipos"
            >
              Arquetipos
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-yellow-500 transition-all group-hover:w-full"></span>
            </a>
          </li> -->
          <li>
            <a 
              class="text-sm font-medium text-gray-700 hover:text-yellow-500 transition-colors relative group" 
              href="#nosotros"
            >
              Nosotros
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-yellow-500 transition-all group-hover:w-full"></span>
            </a>
          </li>
        </ul>
      </nav>

      <!-- CTA & Mobile Menu Button -->
      <div class="flex items-center gap-4">
        <!-- Contact Button (Desktop) -->
        <a 
          href="#contacto" 
          class="hidden md:flex items-center gap-2 bg-gray-900 text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-yellow-500 transition-all hover:scale-105 shadow-sm"
        >
          Contacto
        </a>

        <!-- Mobile Menu Button -->
        <button 
          id="mobile-menu-button"
          class="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors"
          aria-label="Abrir menú"
        >
          <svg
            class="w-6 h-6 text-gray-700"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M4 6h16M4 12h16M4 18h16"
            />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

