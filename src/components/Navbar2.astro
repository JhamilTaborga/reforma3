---
// Navbar.astro
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-10">
    <div class="flex justify-between items-center h-20">
      <!-- Logo -->
      <a href="#inicio" class="flex items-center group">
        <img 
          class="h-10 md:h-12 transition-transform group-hover:scale-105" 
          src="/reforma3-logo-negro-y-blanco.svg" 
          alt="Reforma3 Logo"
        />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:block">
        <ul class="flex items-center gap-12">
          <li>
            <a 
              class="text-sm font-medium text-gray-700 hover:text-yellow-500 transition-colors relative group" 
              href="#inicio"
            >
              Inicio
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-yellow-500 transition-all group-hover:w-full"></span>
            </a>
          </li>
          <li>
            <a 
              class="text-sm font-medium text-gray-700 hover:text-yellow-500 transition-colors relative group" 
              href="#servicios"
            >
              Servicios
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-yellow-500 transition-all group-hover:w-full"></span>
            </a>
          </li>
          <!-- <li>
            <a 
              class="text-sm font-medium text-gray-700 hover:text-yellow-500 transition-colors relative group" 
              href="#proyectos"
            >
              Proyectos
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-yellow-500 transition-all group-hover:w-full"></span>
            </a>
          </li>
          <li>
            <a 
              class="text-sm font-medium text-gray-700 hover:text-yellow-500 transition-colors relative group" 
              href="#arquetipos"
            >
              Arquetipos
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-yellow-500 transition-all group-hover:w-full"></span>
            </a>
          </li> -->
          <li>
            <a 
              class="text-sm font-medium text-gray-700 hover:text-yellow-500 transition-colors relative group" 
              href="#nosotros"
            >
              Nosotros
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-yellow-500 transition-all group-hover:w-full"></span>
            </a>
          </li>
        </ul>
      </nav>

      <!-- CTA & Mobile Menu Button -->
      <div class="flex items-center gap-4">
        <!-- Contact Button (Desktop) -->
        <a 
          href="#contacto" 
          class="hidden md:flex items-center gap-2 bg-gray-900 text-white px-6 py-2.5 rounded-full text-sm font-medium hover:bg-yellow-500 transition-all hover:scale-105 shadow-sm"
        >
          Contacto
        </a>

        <!-- Mobile Menu Button -->
        <button 
          id="mobile-menu-button"
          class="lg:hidden p-2 rounded-lg hover:bg-gray-100 transition-colors"
          aria-label="Abrir menú"
        >
          <svg
            class="w-6 h-6 text-gray-700"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path 
              stroke-linecap="round" 
              stroke-linejoin="round" 
              stroke-width="2" 
              d="M4 6h16M4 12h16M4 18h16"
            />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile Sidebar -->
<div 
  id="mobile-sidebar"
  class="fixed inset-0 z-50 lg:hidden pointer-events-none"
>
  <!-- Backdrop -->
  <div 
    id="sidebar-backdrop"
    class="absolute inset-0 bg-black/50 backdrop-blur-sm opacity-0 transition-opacity duration-300"
  ></div>

  <!-- Sidebar Panel -->
  <div 
    id="sidebar-panel"
    class="absolute top-0 right-0 h-full w-80 max-w-[85vw] bg-white shadow-2xl transform translate-x-full transition-transform duration-300"
