<script>
  const navButtons = document.querySelectorAll('.service-nav-btn');
  
  navButtons.forEach(button => {
    button.addEventListener('click', () => {
      const service = button.getAttribute('data-service');
      const color = button.getAttribute('data-color');

      // Remover clase activa de todos los botones
      navButtons.forEach(btn => {
        const btnColor = btn.getAttribute('data-color');
        btn.classList.remove(`border-${btnColor}-500`, `text-${btnColor}-500`);
        btn.classList.add('hover:bg-gray-100', 'text-gray-blue', 'border-transparent');
      });
      
      // Agregar clase activa al botón clickeado
      button.classList.remove('hover:bg-gray-100', 'text-gray-blue', 'border-transparent');
      button.classList.add(`border-${color}-500`, `text-${color}-500` );

      // Ocultar todo el contenido
      document.querySelectorAll('.service-content').forEach(content => {
        content.classList.add('hidden');
      });
      
      // Mostrar el contenido seleccionado
      document.querySelector(`#content-${service}`)?.classList.remove('hidden');

    });
  });
</script>