---
export interface Props {
  title: string;
  image: string;
  description: string;
}

const { title, image, description } = Astro.props;
---

<a class="bg-black rounded-lg flex flex-col gap-6 sm:flex-row h-fit sm:h-60 w-full px-6 pt-6 pb-2 md:p-6" href="#">
  <div class="flex flex-col w-full md:w-2/3 gap-4 h-full justify-evenly">
    <h2 class="font-bold text-white text-start text-xl md:text-3xl">{title}</h2>
    <p class="text-white text-sm sm:text-base">{description}</p>
  </div>
  <div class="w-full md:w-1/3 flex justify-center items-center">
    <img class="h-fit w-38 md:w-52" src={image} alt="">
  </div>
  
</a>