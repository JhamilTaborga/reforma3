---
export interface Props {
  title: string;
  image: string;
  description: string;
}

const { title, image, description } = Astro.props;
---

<a class="bg-black rounded-lg group relative flex flex-col sm:flex-row h-fit sm:h-60 w-full p-6 items-center justify-around mb-7 " href="#">
  <div class="flex flex-col h-full justify-evenly w-2/3">
    <h2 class="font-bold text-white text-3xl">{title}</h2>
    <p class="text-white text-1xl">{description}</p>
  </div>
  <img class="h-fit w-52" src={image} alt="">
  
</a>