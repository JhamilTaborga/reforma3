---
// ServicesSection.astro
---

<section class="bg-gray-50 my-20 px-6 border-2">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
      <!-- Sidebar de navegación -->
      <aside class="lg:col-span-3">
        <nav class="bg-white rounded-lg shadow-sm p-6">
          <button
            data-service="ingenieria"
            class="service-nav-btn w-full flex items-center gap-3 p-4 rounded-lg transition-all duration-300 mb-2 bg-yellow-400 text-gray-900"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
            </svg>
            <span class="font-medium text-left">Ingeniería</span>
          </button>

          <button
            data-service="tramites"
            class="service-nav-btn w-full flex items-center gap-3 p-4 rounded-lg transition-all duration-300 mb-2 hover:bg-gray-100"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            <span class="font-medium text-left">Trámites</span>
          </button>

          <button
            data-service="diseno"
            class="service-nav-btn w-full flex items-center gap-3 p-4 rounded-lg transition-all duration-300 mb-2 hover:bg-gray-100"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
            </svg>
            <span class="font-medium text-left">Diseño arquitectónico</span>
          </button>

          <button
            data-service="construccion"
            class="service-nav-btn w-full flex items-center gap-3 p-4 rounded-lg transition-all duration-300 hover:bg-gray-100"
          >
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
            <span class="font-medium text-left">Construcción integral</span>
          </button>
        </nav>
      </aside>

      <!-- Contenido principal -->
      <div class="lg:col-span-9">
        <div id="content-ingenieria" class="service-content">
          <div class="flex items-center gap-3 mb-8">
            <svg class="w-8 h-8 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
            </svg>
            <h2 class="text-4xl font-bold text-gray-900">Ingeniería general</h2>
          </div>

          <p class="text-lg text-gray-700 mb-12 leading-relaxed">
            Desarrollamos proyectos arquitectónicos completos, desde el análisis del contexto, investigación de arquetipos, hasta la documentación final, aplicando normativas municipales, criterios técnicos y estándares actuales de diseño moderno.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Paquete básico -->
            <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
              <h3 class="text-2xl font-bold text-gray-900 mb-4">Paquete básico</h3>
              <p class="text-gray-600 mb-8">Ideal para tener una visión clara de tu proyecto.</p>

              <ul class="space-y-4 mb-8">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-gray-900 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-700">Planos arquitectónicos</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-gray-900 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-700">Diseño de fachadas</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-gray-900 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-700">Distribución de espacio</span>
                </li>
              </ul>

              <button class="w-full bg-gray-100 hover:bg-gray-200 text-gray-900 font-medium py-4 px-6 rounded-xl transition-colors duration-300">
                Contactanos por Whatsapp!
              </button>
            </div>

            <!-- Paquete plus -->
            <div class="bg-gradient-to-br from-yellow-400 to-yellow-500 rounded-2xl p-8 shadow-lg relative">
              <div class="absolute top-4 right-4">
                <span class="bg-black text-white text-xs font-bold px-3 py-1 rounded-full">Popular</span>
              </div>

              <h3 class="text-2xl font-bold text-gray-900 mb-4">Paquete plus</h3>
              <p class="text-gray-900 mb-8">Una solución completa para visualizar cada detalle.</p>

              <ul class="space-y-4 mb-8">
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-gray-900 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-900 font-medium">Todo lo del paquete básico</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-gray-900 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-900 font-medium">Renders y visualizaciones 3D</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-gray-900 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-900 font-medium">Selección de materiales</span>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-6 h-6 text-gray-900 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-gray-900 font-medium">Diseño de iluminación</span>
                </li>
              </ul>

              <button class="w-full bg-black hover:bg-gray-900 text-white font-medium py-4 px-6 rounded-xl transition-colors duration-300">
                Contactanos por Whatsapp!
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const navButtons = document.querySelectorAll('.service-nav-btn');
  
  navButtons.forEach(button => {
    button.addEventListener('click', () => {
      const service = button.getAttribute('data-service');
      
      // Remover clase activa de todos los botones
      navButtons.forEach(btn => {
        btn.classList.remove('bg-yellow-400', 'text-gray-900');
        btn.classList.add('hover:bg-gray-100');
      });
      
      // Agregar clase activa al botón clickeado
      button.classList.add('bg-yellow-400', 'text-gray-900');
      button.classList.remove('hover:bg-gray-100');
      
      // Ocultar todo el contenido
      document.querySelectorAll('.service-content').forEach(content => {
        content.classList.add('hidden');
      });
      
      // Mostrar el contenido seleccionado
      document.getElementById(`content-${service}`)?.classList.remove('hidden');
    });
  });
</script>